# ─── ScopeCall Self-Hosted — Environment Variables ────────────────────────────
#
# Copy this file to infra/.env and fill in the required values.
# Never commit infra/.env to version control.
#
# Quick setup:
#   cp infra/.env.example infra/.env
#   echo "AUTH_SECRET=$(openssl rand -hex 32)" >> infra/.env
#   echo "INTERNAL_API_KEY=$(openssl rand -hex 32)" >> infra/.env
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Secret used to sign Auth.js JWTs. Must be at least 32 random bytes.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Shared secret between the Next.js dashboard proxy and the Go API.
# Allows the proxy to authenticate on behalf of logged-in users without
# forwarding their session token to the API. Keep this private.
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Postgres password. Change this in production.
POSTGRES_PASSWORD=scopecall

# ScopeCall image tag. Defaults to "latest"; pin to a version in production.
# Example: SCOPECALL_VERSION=v0.3.1
SCOPECALL_VERSION=latest

# ── API key retention (optional) ──────────────────────────────────────────────
# Revoked API keys are kept in Postgres for this many days for audit, then
# permanently deleted by a background goroutine in the API service. Set to a
# higher number for stricter audit retention. Default is 30; values <= 0 fall
# back to the default with a warning at boot.
# API_KEY_RETENTION_DAYS=30
